# Local dev: Vite proxies /api to the backend (see vite.config).
VITE_DEV_HOST=0.0.0.0
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=http://localhost:3001

# Production / cloud build: set absolute API URL (e.g. GitHub variable VITE_API_BASE_URL_BUSINESS).
# VITE_API_BASE_URL=https://your-api.azurewebsites.net/api/v1
# VITE_API_PROXY_TARGET=https://your-api.azurewebsites.net
