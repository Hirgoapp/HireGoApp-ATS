{
    "name": "ats-saas-backend",
    "version": "1.0.0",
    "description": "ATS SaaS Platform - Backend API",
    "author": "Your Team",
    "license": "UNLICENSED",
    "scripts": {
        "dev": "nest start --watch",
        "dev:full": "node scripts/dev-full.js",
        "dev:all": "node scripts/dev-full.js",
        "ports:check": "node scripts/check-dev-ports.js",
        "smoke:dev": "node scripts/dev-smoke.js",
        "build": "nest build",
        "start": "node dist/main",
        "start:prod": "NODE_ENV=production node dist/main",
        "start:migrate": "node dist/database/data-source.js && node dist/main",
        "start:debug": "nest start --debug --watch",
        "typeorm": "typeorm",
        "migration:generate": "typeorm migration:generate",
        "migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d ormconfig.ts",
        "migration:revert": "typeorm migration:revert",
        "migration:show": "typeorm migration:show",
        "seed": "ts-node src/database/run-seeds.ts",
        "seed:bootstrap": "ts-node src/database/seeds/0-bootstrap-admin.ts",
        "seed:demo": "ts-node src/database/seeds/demo-account.seed.ts",
        "seed:demo:workflows": "ts-node src/database/seeds/demo-workflows.seed.ts",
        "seed:demo:pipelines": "ts-node src/database/seeds/demo-pipelines.seed.ts",
        "seed:demo:interviews": "ts-node src/database/seeds/demo-interviews.seed.ts",
        "seed:demo:offers": "ts-node src/database/seeds/demo-offers.seed.ts",
        "seed:demo:documents": "ts-node src/database/seeds/demo-documents-files.seed.ts",
        "seed:demo:activity": "ts-node src/database/seeds/demo-activity-audit-notifications.seed.ts",
        "seed:demo:platform": "ts-node src/database/seeds/demo-integrations-settings-webhooks.seed.ts",
        "seed:super-admin-invites": "ts-node src/database/seeds/super-admin-invites.seed.ts",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "lint": "eslint src --ext ts",
        "lint:fix": "eslint src --ext ts --fix",
        "format": "prettier --write 'src/**/*.ts'",
        "format:check": "prettier --check 'src/**/*.ts'",
        "docs:openapi:fetch": "powershell -Command \"Invoke-WebRequest http://localhost:3001/api-json -OutFile openapi.json\""
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.71.2",
        "@aws-sdk/client-s3": "^3.964.0",
        "@aws-sdk/s3-request-presigner": "^3.964.0",
        "@google/generative-ai": "^0.24.1",
        "@nestjs/bull": "^11.0.4",
        "@nestjs/cache-manager": "^3.1.0",
        "@nestjs/common": "^10.0.0",
        "@nestjs/config": "^3.0.0",
        "@nestjs/core": "^10.0.0",
        "@nestjs/jwt": "^10.1.0",
        "@nestjs/mapped-types": "^2.1.0",
        "@nestjs/passport": "^10.0.3",
        "@nestjs/platform-express": "^10.0.0",
        "@nestjs/platform-socket.io": "^10.0.0",
        "@nestjs/schedule": "^6.1.0",
        "@nestjs/swagger": "^7.1.0",
        "@nestjs/throttler": "^6.5.0",
        "@nestjs/typeorm": "^10.0.0",
        "@nestjs/websockets": "^10.0.0",
        "@node-saml/node-saml": "^5.1.0",
        "@node-saml/passport-saml": "^5.1.0",
        "@pinecone-database/pinecone": "^6.1.3",
        "@sentry/node": "^10.32.1",
        "@types/bull": "^3.15.9",
        "@types/nodemailer": "^7.0.4",
        "@types/passport-google-oauth20": "^2.0.17",
        "@types/qrcode": "^1.5.6",
        "axios": "^1.13.2",
        "bcrypt": "^5.1.0",
        "bull": "^4.16.5",
        "cache-manager": "^7.2.7",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "dot": "^1.1.3",
        "dotenv": "^16.6.1",
        "helmet": "^8.1.0",
        "js-tiktoken": "^1.0.21",
        "jsonwebtoken": "^9.0.1",
        "mammoth": "^1.12.0",
        "nodemailer": "^7.0.12",
        "openai": "^6.15.0",
        "papaparse": "^5.5.3",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "passport-jwt": "^4.0.1",
        "passport-oauth2": "^1.8.0",
        "passport-saml": "^3.2.4",
        "pdf-parse": "^2.4.5",
        "pdf-to-img": "^5.0.0",
        "pg": "^8.11.0",
        "prom-client": "^15.1.3",
        "qrcode": "^1.5.4",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.1",
        "socket.io": "^4.7.5",
        "speakeasy": "^2.0.0",
        "swagger-ui-express": "^5.0.0",
        "tesseract.js": "^7.0.0",
        "typeorm-extension": "^3.7.3",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.0.0",
        "@nestjs/schematics": "^10.0.0",
        "@nestjs/testing": "^10.0.0",
        "@types/bcrypt": "^5.0.0",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.2",
        "@types/jsonwebtoken": "^9.0.2",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.3.1",
        "@types/passport-jwt": "^3.0.8",
        "@types/pdf-parse": "^1.1.5",
        "@types/supertest": "^2.0.12",
        "@types/uuid": "^9.0.2",
        "@typescript-eslint/eslint-plugin": "^5.59.11",
        "@typescript-eslint/parser": "^5.59.11",
        "concurrently": "^9.2.1",
        "eslint": "^8.42.0",
        "eslint-config-prettier": "^8.8.0",
        "eslint-plugin-prettier": "^4.2.1",
        "jest": "^29.5.0",
        "prettier": "^2.8.8",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.0",
        "ts-loader": "^9.4.3",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typeorm": "^0.3.28",
        "typescript": "^5.3.3"
    }
}
