/**
 * Seed Runner - Execute all seeds including bootstrap
 *
 * Usage:
 *   npx ts-node src/database/run-seeds.ts
 *
 * This runs seeds in order:
 * 1. 0-bootstrap-admin.ts    (Create admin user and company)
 * 2. default-roles-permissions.seed.ts (Create default roles)
 * 3. default-licenses-features.seed.ts (Create licenses)
 * 4. default-custom-fields.seed.ts (Create custom fields)
 * 5. default-candidates.seed.ts (Create sample candidates)
 * 6. default-jobs.seed.ts (Create sample jobs)
 * 7. super-admin.seed.ts (Create global super admin)
 */

import 'reflect-metadata';
import { DataSource } from 'typeorm';
import { ConfigService } from '@nestjs/config';
import * as path from 'path';
import { config as dotenvConfig } from 'dotenv';
import { Company } from '../companies/entities/company.entity';
import { User } from '../auth/entities/user.entity';
import { Role } from '../auth/entities/role.entity';
import { Permission } from '../auth/entities/permission.entity';
import { RolePermission } from '../auth/entities/role-permission.entity';
import { RolePermissionAudit } from '../auth/entities/role-permission-audit.entity';
import { UserPermission } from '../auth/entities/user-permission.entity';
import { SuperAdminUser } from '../super-admin/entities/super-admin-user.entity';

// Load environment variables
dotenvConfig({ path: path.join(__dirname, '../../.env') });

// Import seed functions (DISABLED - needs update for single-tenant schema)
// import { bootstrapAdminUser } from './seeds/0-bootstrap-admin';
// import { seedSuperAdminUser } from './seeds/super-admin.seed';

/**
 * Create and initialize TypeORM DataSource
 */
function createDataSource(): DataSource {
    return new DataSource({
        type: 'postgres',
        host: process.env.DB_HOST || 'localhost',
        port: parseInt(process.env.DB_PORT || '5432'),
        username: process.env.DB_USERNAME || 'postgres',
        password: process.env.DB_PASSWORD || 'password',
        database: process.env.DB_NAME || 'ats_saas',
        entities: [
            Company,
            User,
            Role,
            Permission,
            RolePermission,
            RolePermissionAudit,
            UserPermission,
            SuperAdminUser,
        ],
        synchronize: false,
        logging: false,
    });
}

/**
 * Run all seeds
 */
async function runSeeds(dataSource: DataSource) {
    console.log('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—');
    console.log('в•‘      ATS SaaS - Database Seed Runner         в•‘');
    console.log('в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n');

    try {
        // Initialize database connection
        console.log('рџ”Њ Connecting to database...');
