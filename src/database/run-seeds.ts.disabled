    } catch (error) {
        console.error('\nвќЊ Seeding failed:', error.message);
        console.error(error);
        process.exit(1);
    } finally {
        // Close database connection
        if (dataSource.isInitialized) {
            await dataSource.destroy();
        }
    }
}

/**
 * Main entry point
 */
async function main() {
    const dataSource = createDataSource();
    await runSeeds(dataSource);
}

// Execute
main().catch((error) => {
    console.error('Fatal error:', error);
    process.exit(1);
});
