# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development
PORT=3001
HOST=0.0.0.0
PUBLIC_HOST=http://localhost:3001

# PostgreSQL — individual connection variables (used for local dev).
# On Railway, set DATABASE_URL instead (the PostgreSQL plugin provides it automatically).
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=ats_saas
# DB_SSL=true  # Set to true when connecting to Railway/managed Postgres over SSL
# DB_SSL_REJECT_UNAUTHORIZED=false  # Set to false only if your provider uses self-signed certs

# Railway PostgreSQL plugin injects this automatically.
# When set, it overrides DB_HOST / DB_PORT / DB_USERNAME / DB_PASSWORD / DB_DATABASE.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis / Bull — individual connection variables (used for local dev).
# On Railway, set REDIS_URL instead (the Redis plugin provides it automatically).
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=
# REDIS_TLS=true  # Set to true for Azure Cache for Redis (port 6380)

# Railway Redis plugin injects this automatically.
# When set, it overrides REDIS_HOST / REDIS_PORT / REDIS_PASSWORD / REDIS_TLS.
# REDIS_URL=redis://:password@host:6379

JWT_SECRET=change-me-in-production

# Set to true on Railway (or any PaaS) to auto-run pending DB migrations on startup.
# RUN_MIGRATIONS=true

# Base URL for invitation accept links (appends /invite/accept?token=…)
# INVITATION_ACCEPT_BASE_URL=http://localhost:3001

# Comma-separated origins when not using localhost defaults
# CORS_ORIGIN=https://your-app.azurestaticapps.net,https://your-admin.azurestaticapps.net

# JD uploads — scanned PDF OCR (pdf-to-img + tesseract.js). Requires Node 20+.
# JD_PDF_OCR_ENABLED=true
# JD_PDF_OCR_MIN_CHARS=80
# JD_PDF_OCR_MAX_PAGES=8
# JD_PDF_OCR_LANG=eng

# ──────────────────────────────────────────────────────────────────────────────
# Railway deployment quick-reference
# ──────────────────────────────────────────────────────────────────────────────
# 1. Connect a PostgreSQL plugin → Railway auto-sets DATABASE_URL
# 2. Connect a Redis plugin      → Railway auto-sets REDIS_URL
# 3. Set these env vars manually in the Railway service:
#      NODE_ENV=production
#      JWT_SECRET=<strong-random-secret>
#      RUN_MIGRATIONS=true          # runs pending migrations on every deploy
#      CORS_ORIGIN=https://your-frontend.up.railway.app,https://your-admin.up.railway.app
# 4. Railway injects PORT automatically — no need to set it manually.
# ──────────────────────────────────────────────────────────────────────────────
