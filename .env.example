# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development
PORT=3001
HOST=0.0.0.0
PUBLIC_HOST=http://localhost:3001

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=ats_saas

# Redis / Bull — set REDIS_TLS=true for Azure Cache for Redis (port 6380)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=

JWT_SECRET=change-me-in-production

# Base URL for invitation accept links (appends /invite/accept?token=…)
# INVITATION_ACCEPT_BASE_URL=http://localhost:3001

# Comma-separated origins when not using localhost defaults
# CORS_ORIGIN=https://your-app.azurestaticapps.net,https://your-admin.azurestaticapps.net

# JD uploads — scanned PDF OCR (pdf-to-img + tesseract.js). Requires Node 20+.
# JD_PDF_OCR_ENABLED=true
# JD_PDF_OCR_MIN_CHARS=80
# JD_PDF_OCR_MAX_PAGES=8
# JD_PDF_OCR_LANG=eng
